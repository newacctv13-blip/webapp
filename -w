<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Заказы</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/static/style.css">
</head>
<body>
  <nav class="navbar navbar-dark bg-dark mb-4">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">
        <i class="bi bi-shop"></i> Админка заказов
      </a>
      <span class="navbar-text text-light small">
        Telegram Bot Admin
      </span>
    </div>
  </nav>

  <div class="container-fluid px-4">
    
      
    

    
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <h4 class="mb-0"><i class="bi bi-list-ul"></i> Заказы</h4>
  <div class="d-flex gap-2 flex-wrap">
    <a href="/" class="btn btn-outline-secondary btn-sm active">Все</a>
    
      <a href="/?status=new&amp;search="
         class="btn btn-outline-secondary btn-sm ">
        Новый
      </a>
    
      <a href="/?status=accepted&amp;search="
         class="btn btn-outline-secondary btn-sm ">
        Принят
      </a>
    
      <a href="/?status=confirmed&amp;search="
         class="btn btn-outline-secondary btn-sm ">
        Подтвержден
      </a>
    
      <a href="/?status=processing&amp;search="
         class="btn btn-outline-secondary btn-sm ">
        В обработке
      </a>
    
      <a href="/?status=delivered&amp;search="
         class="btn btn-outline-secondary btn-sm ">
        Доставлен
      </a>
    
    <a href="/?status=cancelled&amp;search="
       class="btn btn-outline-danger btn-sm ">
      Отменённые
    </a>
  </div>
</div>

<form method="GET" action="/" class="row g-2 mb-3">
  <div class="col-auto">
    <input type="text" name="search" class="form-control form-control-sm" placeholder="Поиск (имя, телефон, город...)" value="">
  </div>
  <div class="col-auto">
    <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-search"></i></button>
  </div>
  
</form>


<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>#</th>
        <th>Имя</th>
        <th>Телефон</th>
        <th>Город</th>
        <th>Состав заказа</th>
        <th>Сумма</th>
        <th>Доставка</th>
        <th>К оплате</th>
        <th>Дата/Время</th>
        <th>Статус</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      
      <tr class="order-row status-delivered">
        <td>4</td>
        <td>Alexandr Ghirju</td>
        <td>069387017</td>
        <td>Chișinău</td>
        <td class="text-wrap" style="max-width: 220px;">• Корзиночка с фруктами × 3 = 84 L</td>
        <td>154 L</td>
        <td>60 L</td>
        <td><strong>214 L</strong></td>
        <td class="small">18.06.2026 12:54</td>
        <td>
          
            <span class="badge bg-success">
              Доставлен
            </span>
          
        </td>
        <td>
          
          <div class="d-flex gap-1 flex-wrap">
            <form method="POST" action="/update_status/4" class="d-inline">
              <select name="status" class="form-select form-select-sm d-inline" style="width:auto; display:inline-block!important;" onchange="this.form.submit()">
                <option value="">Сменить...</option>
                
                  
                    <option value="new">Новый</option>
                  
                
                  
                    <option value="accepted">Принят</option>
                  
                
                  
                    <option value="confirmed">Подтвержден</option>
                  
                
                  
                    <option value="processing">В обработке</option>
                  
                
                  
                
              </select>
            </form>
            <form method="POST" action="/cancel/4" class="d-inline" onsubmit="return confirm('Отменить заказ #4?')">
              <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-x-circle"></i></button>
            </form>
          </div>
          
        </td>
      </tr>
      
      <tr class="order-row status-cancelled">
        <td>3</td>
        <td>—</td>
        <td>—</td>
        <td>—</td>
        <td class="text-wrap" style="max-width: 220px;">—</td>
        <td>—</td>
        <td>—</td>
        <td><strong>—</strong></td>
        <td class="small">18.06.2026 12:52</td>
        <td>
          
            <span class="badge bg-danger">Отменён</span>
          
        </td>
        <td>
          
            <span class="text-muted small">—</span>
          
        </td>
      </tr>
      
      <tr class="order-row status-confirmed">
        <td>2</td>
        <td>Твоао</td>
        <td>76541908</td>
        <td>Chișinău</td>
        <td class="text-wrap" style="max-width: 220px;">• Пирожное картошка × 1 = 25 L</td>
        <td>25 L</td>
        <td>60 L</td>
        <td><strong>85 L</strong></td>
        <td class="small">18.06.2026 12:52</td>
        <td>
          
            <span class="badge bg-info">
              Подтвержден
            </span>
          
        </td>
        <td>
          
          <div class="d-flex gap-1 flex-wrap">
            <form method="POST" action="/update_status/2" class="d-inline">
              <select name="status" class="form-select form-select-sm d-inline" style="width:auto; display:inline-block!important;" onchange="this.form.submit()">
                <option value="">Сменить...</option>
                
                  
                    <option value="new">Новый</option>
                  
                
                  
                    <option value="accepted">Принят</option>
                  
                
                  
                
                  
                    <option value="processing">В обработке</option>
                  
                
                  
                    <option value="delivered">Доставлен</option>
                  
                
              </select>
            </form>
            <form method="POST" action="/cancel/2" class="d-inline" onsubmit="return confirm('Отменить заказ #2?')">
              <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-x-circle"></i></button>
            </form>
          </div>
          
        </td>
      </tr>
      
      <tr class="order-row status-cancelled">
        <td>1</td>
        <td>—</td>
        <td>—</td>
        <td>—</td>
        <td class="text-wrap" style="max-width: 220px;">—</td>
        <td>—</td>
        <td>—</td>
        <td><strong>—</strong></td>
        <td class="small">18.06.2026 12:52</td>
        <td>
          
            <span class="badge bg-danger">Отменён</span>
          
        </td>
        <td>
          
            <span class="text-muted small">—</span>
          
        </td>
      </tr>
      
    </tbody>
  </table>
</div>


  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>